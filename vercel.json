{
  "version": 2,
  "builds": [
    {
      "src": "vercel/app.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.11",
        "installer": "uv",
        "maxLambdaSize": "50mb",
        "includeFiles": "src/tv_mcp/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel/app.py"
    }
  ]
}