# Example environment file for tradingview-mcp
# Copy this file to .env and replace placeholder values before running

# TradingView session cookie (escaped if necessary)
TRADINGVIEW_COOKIE='YOUR_ESCAPED_TRADINGVIEW_COOKIE_HERE'
# Public URL for OpenAPI spec and docs (recommended on Vercel so /openapi.json shows this URL)
# Set to your stable alias, e.g. https://tradingview-mcp.vercel.app (Vercel sets VERCEL_URL to the deployment URL)
PUBLIC_APP_URL="https://tradingview-mcp.vercel.app"
# Vercel sets this automatically to the deployment hostname; overridden by PUBLIC_APP_URL when set
# VERCEL_URL="https://your-app.vercel.app"
# Default chart URL
TRADINGVIEW_URL="https://www.tradingview.com/chart/your_chart_id/?symbol=BINANCE%3ABTCUSDT"


# TradingView Configuration (Optional - defaults will be used if not set)
TRADINGVIEW_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"


# Security keys used by the FastAPI app
# - TV_ADMIN_KEY: used for administrative endpoints (e.g., /update-cookies). Keep secret.
# - TV_CLIENT_KEY: used by clients (GPTs, plugins) to call data endpoints.
TV_ADMIN_KEY="<your-admin-key-here>"
TV_CLIENT_KEY="<your-client-key-here>"

