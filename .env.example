# Example environment file for tradingview-mcp
# Copy this file to .env and replace placeholder values before running

# TradingView session cookie (escaped if necessary)
TRADINGVIEW_COOKIE='YOUR_ESCAPED_TRADINGVIEW_COOKIE_HERE'
# Default chart URL
TRADINGVIEW_URL="https://www.tradingview.com/chart/your_chart_id/?symbol=BINANCE%3ABTCUSDT"


# TradingView Configuration (Optional - defaults will be used if not set)
TRADINGVIEW_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64; rv:140.0) Gecko/20100101 Firefox/140.0"


# Client key used by remote MCP clients over HTTP/SSE
TV_CLIENT_KEY="<your-client-key-here>"

# Optional OAuth JWT validation (Bearer token), with API key fallback.
# TV_OAUTH_JWKS_URL="https://issuer.example/.well-known/jwks.json"
# TV_OAUTH_ISSUER="https://issuer.example/"
# TV_OAUTH_AUDIENCE="your-api-audience"
# TV_OAUTH_REQUIRED_SCOPE="mcp.read"
# TV_OAUTH_ALGORITHMS="RS256"
# TV_OAUTH_LEEWAY_SECONDS="30"

# Optional bind/path overrides for local runners
# MCP_HTTP_HOST="0.0.0.0"
# MCP_HTTP_PORT="8000"
# MCP_HTTP_PATH="/sse"
# MCP_SSE_PATH="/sse"

